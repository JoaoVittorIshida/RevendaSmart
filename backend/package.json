{
    "name": "revenda-smart-backend",
    "version": "1.0.0",
    "description": "API para o sistema RevendaSmart",
    "main": "server.js",
    "scripts": {
        "start": "npm run db:migrate && node server.js",
        "dev": "npm run db:migrate && nodemon server.js",
