        "express": "^4.18.2",
        "express-rate-limit": "^8.3.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "mysql2": "^3.6.5",
        "sanitize-html": "^2.17.6"
    },
    "devDependencies": {
        "nodemon": "^3.0.2"
    }
